{
  "name": "@raphi93/shome-components",
  "version": "1.4.15",
  "description": "Small React + TypeScript component library with CSS variable theming.",
  "author": "RHUG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphi93/shome-components.git"
  },
  "homepage": "https://shome-wiki.raphaelhug.ch/",
  "bugs": {
    "url": "https://github.com/raphi93/shome-components/issues"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "rollup": "rollup -c && sass src/styles.scss dist/styles.css --no-source-map",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "echo \"no tests\" && exit 0",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "keywords": [
    "react",
    "components",
    "typescript",
    "css-variables"
  ],
  "peerDependencies": {
    "react":            ">=18",
    "react-dom":        ">=18",
    "react-router-dom": ">=6.0.0",
    "react-i18next":    ">=16.0.0",
    "i18next":          ">=25.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": { "optional": true },
    "react-i18next":    { "optional": true },
    "i18next":          { "optional": true }
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@floating-ui/react": "^0.27.19",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.2",
    "@tiptap/extension-color": "^3.22.2",
    "@tiptap/extension-font-family": "^3.22.2",
    "@tiptap/extension-highlight": "^3.22.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/extension-subscript": "^3.22.2",
    "@tiptap/extension-superscript": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-text-align": "^3.22.2",
    "@tiptap/extension-text-style": "^3.22.2",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
