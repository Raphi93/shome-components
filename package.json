{
  "name": "@raphi93/shome-components",
  "version": "1.3.51",
  "description": "Small React + TypeScript component library with CSS variable theming.",
  "author": "RHUG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphi93/shome-components.git"
  },
  "homepage": "https://shome-wiki.raphaelhug.ch/",
  "bugs": {
    "url": "https://github.com/raphi93/shome-components/issues"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "rollup": "rollup -c --bundleConfigAsCjs",
    "test": "echo \"no tests\" && exit 0",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "keywords": [
    "react",
    "components",
    "typescript",
    "css-variables"
  ],
  "peerDependencies": {
    "next": "^16.1.6",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
