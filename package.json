{
  "name": "@raphi93/shome-components",
  "version": "1.4.2",
  "description": "Small React + TypeScript component library with CSS variable theming.",
  "author": "RHUG",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raphi93/shome-components.git"
  },
  "homepage": "https://shome-wiki.raphaelhug.ch/",
  "bugs": {
    "url": "https://github.com/raphi93/shome-components/issues"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "rollup": "rollup -c && sass src/styles.scss dist/styles.css --no-source-map",
    "test": "echo \"no tests\" && exit 0",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "keywords": [
    "react",
    "components",
    "typescript",
    "css-variables"
  ],
  "peerDependencies": {
    "@floating-ui/react": ">=0.27.0",
    "@fortawesome/fontawesome-svg-core": ">=7.0.0",
    "@fortawesome/free-brands-svg-icons": ">=7.0.0",
    "@fortawesome/free-regular-svg-icons": ">=7.0.0",
    "@fortawesome/free-solid-svg-icons": ">=7.0.0",
    "@fortawesome/react-fontawesome": ">=3.0.0",
    "date-fns": ">=4.0.0",
    "i18next": ">=25.0.0",
    "lodash": ">=4.17.0",
    "next": ">=13.0.0",
    "react": ">=18",
    "react-datepicker": ">=9.0.0",
    "react-dom": ">=18",
    "react-i18next": ">=16.0.0",
    "react-icons": ">=5.0.0",
    "react-responsive": ">=10.0.0",
    "react-select": ">=5.0.0",
    "react-speech-recognition": ">=4.0.0",
    "react-router-dom": ">=6.0.0",
    "react-spinners": ">=0.17.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    },
    "lodash": {
      "optional": true
    },
    "react-datepicker": {
      "optional": true
    },
    "react-icons": {
      "optional": true
    },
    "react-responsive": {
      "optional": true
    },
    "react-speech-recognition": {
      "optional": true
    },
    "react-router-dom": { "optional": true },
    "react-spinners": { "optional": true }
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-speech-recognition": "^3.9.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^9.1.20",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "postcss-modules": "^6.0.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-preserve-directives": "^1.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "typescript": "^6.0.2"
  }
}
