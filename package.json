    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-preserve-directives": "^1.1.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "storybook": "^10.3.4",
    "style-loader": "^4.0.0",
